# Vite only exposes env vars prefixed VITE_ to client-side code.
# Copy to .env.local for local development (never commit .env/.env.local — see root .gitignore).

# Business API base URL (backend/raad/interfaces/http/api_v1.py's /api/v1 prefix).
VITE_API_BASE_URL=http://localhost:8000/api/v1

# WebSocket base URL (backend/raad/interfaces/http/ws.py's /ws/tracking, /ws/notifications).
VITE_WS_BASE_URL=ws://localhost:8000
