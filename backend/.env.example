# Backend environment configuration template — placeholder only.
# No real secrets. Populate per-environment values via a secrets manager, not this file.
#
# Variable names match core/config/settings.py exactly: RAAD_<GROUP>__<FIELD>
# (double underscore is the nested-settings delimiter — see Settings.model_config).

# --- Application ---
# RAAD_ENVIRONMENT=dev   # dev | staging | prod

# --- Database (MySQL 8.x) — not yet connected in this phase ---
# RAAD_DB__URL=
# RAAD_DB__POOL_SIZE=5

# --- Redis — not yet connected in this phase ---
# RAAD_REDIS__URL=

# --- Event Broker — not yet connected in this phase ---
# RAAD_BROKER__URL=

# --- Auth (JWT) — not yet wired in this phase ---
# RAAD_AUTH__JWT_SECRET_KEY=
# RAAD_AUTH__JWT_ALGORITHM=HS256
# RAAD_AUTH__ACCESS_TOKEN_TTL_SECONDS=900
# RAAD_AUTH__REFRESH_TOKEN_TTL_SECONDS=1209600

# --- FCM (Push Notifications) — not yet wired in this phase ---
# RAAD_FCM__CREDENTIALS_PATH=

# --- Payment Provider (EVC Plus) — not yet wired in this phase ---
# RAAD_PAYMENT__PROVIDER=evcplus

# --- Maps — not yet wired in this phase ---
# RAAD_MAPS__PROVIDER=

# --- Device Plane signaling (JT808/JT1078 seam, D6) — not yet wired in this phase ---
# RAAD_DEVICE_PLANE__JT808_SIGNALING_URL=
# RAAD_DEVICE_PLANE__JT1078_SIGNALING_URL=

# --- Observability ---
# RAAD_OBSERVABILITY__LOG_LEVEL=INFO
# RAAD_OBSERVABILITY__LOG_FORMAT=json
